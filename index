<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A Surprise For You! 🎁</title>
<!-- ===== WhatsApp / social preview tags =====
     IMPORTANT: after hosting, replace https://chenzebfaiz.github.io/zihan-bithday below with your real link
     e.g. https://zihan-turns-2.netlify.app  (no trailing slash) -->
<meta property="og:title" content="Psst... A surprise awaits you! 🎁">
<meta property="og:description" content="A little someone is turning a year older — tap to open your surprise!">
<meta property="og:image" content="https://chenzebfaiz.github.io/zihan-bithday/thumbnail.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:url" content="https://chenzebfaiz.github.io/zihan-bithday/">
<meta property="og:type" content="website">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --sky:#EAF6FB;
    --cloud:#FFFFFF;
    --blue:#BBDDF5;
    --butter:#FDE7A9;
    --mint:#CDEBDD;
    --ink:#2E4A6B;
    --soft-ink:#6E86A6;
    --royal:#4A90D9;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{height:100%;}
  body{
    font-family:'Quicksand',sans-serif;
    background:linear-gradient(180deg,#CDE7F7 0%, var(--sky) 45%, #DDEEFA 100%);
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:24px 14px;
    color:var(--ink);
    overflow-x:hidden;
  }

  /* ============ COVER / GIFT SCREEN ============ */
  .cover{
    position:fixed;
    inset:0;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:8px;
    background:linear-gradient(180deg,#BFE0F6 0%, #EAF6FB 60%, #DDEEFA 100%);
    z-index:10;
    cursor:pointer;
    transition:opacity .7s ease, visibility .7s;
    text-align:center;
    padding:20px;
  }
  .cover.opened{opacity:0;visibility:hidden;pointer-events:none;}

  .cover .teaser{
    font-family:'Baloo 2',cursive;
    font-size:clamp(22px,6vw,30px);
    font-weight:800;
    color:var(--ink);
    margin-bottom:2px;
  }
  .cover .teaser-sub{
    font-size:15px;
    font-weight:600;
    color:var(--soft-ink);
    margin-bottom:28px;
  }

  .gift{
    position:relative;
    width:150px;
    height:150px;
    animation:bounce 1.6s ease-in-out infinite;
    filter:drop-shadow(0 14px 22px rgba(46,74,107,.25));
  }
  @keyframes bounce{
    0%,100%{transform:translateY(0) rotate(-2deg);}
    50%{transform:translateY(-14px) rotate(2deg);}
  }
  .gift .box{
    position:absolute;
    bottom:0;left:15px;
    width:120px;height:92px;
    background:linear-gradient(180deg,#5FA8E8,#4A90D9);
    border-radius:10px;
  }
  .gift .ribbon-v{
    position:absolute;
    bottom:0;left:63px;
    width:24px;height:92px;
    background:var(--butter);
  }
  .gift .lid{
    position:absolute;
    top:22px;left:5px;
    width:140px;height:34px;
    background:linear-gradient(180deg,#7BBCF0,#5FA8E8);
    border-radius:8px;
    transition:transform .6s cubic-bezier(.34,1.56,.64,1), opacity .6s;
    transform-origin:left bottom;
  }
  .gift .ribbon-lid{
    position:absolute;
    top:22px;left:63px;
    width:24px;height:34px;
    background:#FBD97F;
    transition:transform .6s cubic-bezier(.34,1.56,.64,1), opacity .6s;
    transform-origin:left bottom;
  }
  .gift .bow{
    position:absolute;
    top:-4px;left:50%;
    transform:translateX(-50%);
    font-size:36px;
    transition:transform .5s, opacity .5s;
  }
  .cover.opening .lid,
  .cover.opening .ribbon-lid{
    transform:rotate(-55deg) translateY(-40px);
    opacity:0;
  }
  .cover.opening .bow{transform:translateX(-50%) translateY(-70px) rotate(30deg);opacity:0;}
  .cover.opening .gift{animation:none;}

  .tap-hint{
    margin-top:30px;
    font-family:'Baloo 2',cursive;
    font-size:17px;
    font-weight:700;
    color:var(--royal);
    background:#FFF;
    padding:12px 28px;
    border-radius:999px;
    box-shadow:0 8px 20px rgba(74,144,217,.25);
    animation:pulse 1.6s ease-in-out infinite;
  }
  @keyframes pulse{
    0%,100%{transform:scale(1);}
    50%{transform:scale(1.07);}
  }

  /* ============ CONFETTI ============ */
  .confetti-piece{
    position:fixed;
    top:-20px;
    width:10px;height:14px;
    z-index:9;
    border-radius:3px;
    animation:fall linear forwards;
    pointer-events:none;
  }
  @keyframes fall{
    to{transform:translateY(110vh) rotate(720deg);}
  }

  /* ============ INVITATION CARD ============ */
  .card{
    position:relative;
    width:100%;
    max-width:430px;
    background:var(--cloud);
    border-radius:36px;
    padding:52px 34px 40px;
    box-shadow:0 18px 50px rgba(46,74,107,.16);
    overflow:hidden;
    text-align:center;
    border:6px solid #FFF;
    outline:3px dashed var(--blue);
    outline-offset:-14px;
    opacity:0;
    transform:scale(.85) translateY(30px);
    transition:opacity .8s ease .5s, transform .8s cubic-bezier(.34,1.4,.64,1) .5s;
  }
  .card.show{opacity:1;transform:scale(1) translateY(0);}

  .float{position:absolute;user-select:none;pointer-events:none;animation:drift 6s ease-in-out infinite;}
  .moon{top:18px;right:22px;font-size:44px;animation-delay:.5s;}
  .star1{top:64px;left:26px;font-size:22px;animation-delay:1.2s;}
  .star2{top:120px;right:60px;font-size:16px;animation-delay:2s;}
  .cloud1{bottom:90px;left:-6px;font-size:38px;opacity:.7;animation-delay:.8s;}
  .cloud2{top:150px;left:52px;font-size:24px;opacity:.6;animation-delay:1.6s;}
  .teddy{bottom:26px;right:26px;font-size:30px;animation-delay:.3s;}
  @keyframes drift{
    0%,100%{transform:translateY(0);}
    50%{transform:translateY(-8px);}
  }
  @media (prefers-reduced-motion: reduce){
    .float,.gift,.tap-hint{animation:none;}
    .card{transition:opacity .3s;}
  }

  .eyebrow{
    display:inline-block;
    background:var(--butter);
    color:var(--ink);
    font-weight:700;
    font-size:12px;
    letter-spacing:2.5px;
    text-transform:uppercase;
    padding:7px 18px;
    border-radius:999px;
    margin-bottom:18px;
  }
  h1{
    font-family:'Baloo 2',cursive;
    font-size:clamp(34px,9vw,44px);
    font-weight:800;
    line-height:1.08;
    color:var(--royal);
    margin-bottom:6px;
  }
  .sub{
    font-family:'Baloo 2',cursive;
    font-size:19px;
    font-weight:600;
    color:var(--soft-ink);
    margin-bottom:26px;
  }
  .baby-name{
    font-family:'Baloo 2',cursive;
    font-size:26px;
    font-weight:700;
    color:var(--ink);
    background:linear-gradient(90deg,var(--blue),#D6EBFA,var(--mint));
    border-radius:20px;
    padding:12px 10px;
    margin:0 auto 28px;
    max-width:320px;
  }
  .details{
    display:grid;
    gap:14px;
    margin-bottom:24px;
    text-align:left;
  }
  .row{
    display:flex;
    align-items:flex-start;
    gap:14px;
    background:#FAFBFE;
    border-radius:18px;
    padding:14px 16px;
  }
  .row .icon{font-size:24px;line-height:1.2;flex:0 0 auto;}
  .row .label{
    font-size:11px;
    font-weight:700;
    letter-spacing:1.8px;
    text-transform:uppercase;
    color:var(--soft-ink);
    margin-bottom:2px;
  }
  .row .value{
    font-size:16px;
    font-weight:600;
    color:var(--ink);
    line-height:1.35;
  }
  .timing-note{
    background:var(--blue);
    border-radius:18px;
    padding:14px 18px;
    font-size:13.5px;
    font-weight:600;
    color:#2B4E75;
    line-height:1.5;
    margin-bottom:26px;
  }
  .timing-note strong{font-weight:700;}
  .footer-line{
    margin-top:8px;
    font-size:13px;
    color:var(--soft-ink);
    font-weight:500;
    font-style:italic;
  }
</style>
</head>
<body>

  <!-- COVER SCREEN -->
  <div class="cover" id="cover">
    <div class="teaser">Psst... 🤫</div>
    <div class="teaser-sub">A little someone is turning a year older...<br>and you're on his special guest list! 🎂</div>
    <div class="gift">
      <div class="box"></div>
      <div class="ribbon-v"></div>
      <div class="lid"></div>
      <div class="ribbon-lid"></div>
      <div class="bow">🎀</div>
    </div>
    <div class="tap-hint">👆 Tap to open your surprise</div>
  </div>

  <!-- INVITATION CARD -->
  <div class="card" id="card">
    <span class="float moon">🌙</span>
    <span class="float star1">⭐</span>
    <span class="float star2">✨</span>
    <span class="float cloud1">☁️</span>
    <span class="float cloud2">☁️</span>
    <span class="float teddy">🧸</span>

    <span class="eyebrow">🎂 2nd Birthday Party 🎂</span>
    <h1>Our Little Prince<br>Is Turning 2! 👑</h1>
    <p class="sub">Join us for a joyful evening<br>to celebrate the 2nd birthday of</p>

    <div class="baby-name">🎈 Zihan Kayani 🎈</div>

    <div class="details">
      <div class="row">
        <span class="icon">📅</span>
        <div>
          <div class="label">When</div>
          <div class="value">Sunday, 26 July 2026<br>5:00 PM – 8:00 PM</div>
        </div>
      </div>
      <div class="row">
        <span class="icon">📍</span>
        <div>
          <div class="label">Where</div>
          <div class="value">Mernda Community Centre<br>Mernda, Victoria</div>
        </div>
      </div>
    </div>

    <div class="timing-note">
      🍽️ <strong>Dinner will be served sharp at 6:00 PM</strong> — don't miss it!<br><br>
      ⏰ <strong>Kindly note:</strong> our booking ends sharp at 8:00 PM and the venue closes access at 8:30 PM — so please arrive on time so we can enjoy every moment together!
    </div>

    <p class="footer-line">Your presence will make our celebration complete ♡</p>
  </div>

<script>
  const cover = document.getElementById('cover');
  const card = document.getElementById('card');
  const colors = ['#4A90D9','#FDE7A9','#CDEBDD','#BBDDF5','#FFFFFF','#7BBCF0'];
  let opened = false;

  function confettiBurst(){
    for(let i = 0; i < 80; i++){
      const c = document.createElement('div');
      c.className = 'confetti-piece';
      c.style.left = Math.random() * 100 + 'vw';
      c.style.background = colors[Math.floor(Math.random() * colors.length)];
      c.style.animationDuration = (2.2 + Math.random() * 2.5) + 's';
      c.style.animationDelay = (Math.random() * 0.8) + 's';
      c.style.width = (7 + Math.random() * 7) + 'px';
      c.style.height = (10 + Math.random() * 8) + 'px';
      document.body.appendChild(c);
      setTimeout(() => c.remove(), 6000);
    }
  }

  cover.addEventListener('click', () => {
    if(opened) return;
    opened = true;
    cover.classList.add('opening');
    setTimeout(() => {
      confettiBurst();
      cover.classList.add('opened');
      card.classList.add('show');
    }, 650);
  });
</script>
</body>
</html>